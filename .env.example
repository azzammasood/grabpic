# Copy to .env and adjust for local runs (optional if using docker-compose defaults).

DATABASE_URL=postgresql://grabpic:grabpic@localhost:5432/grabpic
STORAGE_PATH=./storage

# DeepFace model name (must stay consistent between ingest and auth).
FACE_MODEL=Facenet512
DETECTOR_BACKEND=retinaface

# Minimum cosine similarity to treat two embeddings as the same identity.
# Increase for stricter matching (fewer false accepts), decrease if legitimate matches fail.
MATCH_THRESHOLD=0.42
